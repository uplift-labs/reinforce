{
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.reinforce/adapter/hooks/stop.sh\"",
            "timeout": 30000,
            "statusMessage": "[reinforce] Session reflection check..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.reinforce/adapter/hooks/user-prompt.sh\"",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.reinforce/adapter/hooks/session-start.sh\"",
            "timeout": 10000,
            "statusMessage": "[reinforce] Checking reflections..."
          }
        ]
      }
    ]
  }
}
